{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "db:generate": {
            "cache": false
        },
        "build": {
            "dependsOn": ["^db:generate", "^build"],
            "outputs": [".next/**", "!.next/cache/**", "dist/**"]
        },
        "dev": {
            "dependsOn": ["^db:generate"],
            "persistent": true,
            "cache": false
        },
        "lint": {
            "dependsOn": ["^db:generate"]
        }
    }
}
