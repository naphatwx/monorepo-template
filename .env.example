# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# RabbitMQ
# Set to true to enable RabbitMQ in api and worker. Default false lets you
# run only api and web without a broker. RABBITMQ_URL is required when true.
RABBITMQ_ENABLE=false
RABBITMQ_URL=amqp://rabbit:rabbit@localhost:5672

# API
PORT=4000
FRONTEND_URL=http://localhost:3000

# Web
# Used by the browser. The proxy route also reads this as a fallback.
NEXT_PUBLIC_API_URL=http://localhost:4000
# Used by the web server (Server Components, proxy route) to reach the API.
API_INTERNAL_URL=http://localhost:4000
